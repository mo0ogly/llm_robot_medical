---
title: Boucle agentique 8 étapes (chaque agent pense avant d'agir)
---
flowchart TD
    OBJECTIVE["<b>OBJECTIVE</b><br/><i>Quel est mon objectif spécifique ?</i>"]
    DECOMPOSE["<b>DECOMPOSE</b><br/><i>Quelles sous-tâches sont nécessaires ?</i>"]
    PLAN["<b>PLAN</b><br/><i>Dans quel ordre les exécuter ?</i>"]
    ACT["<b>ACT</b><br/><i>Exécuter l'action<br/>(WebSearch, Read, Write...)</i>"]
    OBSERVE["<b>OBSERVE</b><br/><i>Quel est le résultat de mon action ?</i>"]
    EVALUATE{"<b>EVALUATE</b><br/><i>Résultat suffisant ?<br/>Critères atteints ?</i>"}
    REPLAN["<b>REPLAN</b><br/><i>Ajuster le plan<br/>et ré-exécuter</i>"]
    COMPLETE(["<b>COMPLETE</b><br/><i>Produire le livrable final<br/>+ DIFF</i>"])

    OBJECTIVE --> DECOMPOSE
    DECOMPOSE --> PLAN
    PLAN --> ACT
    ACT --> OBSERVE
    OBSERVE --> EVALUATE
    EVALUATE -->|NON| REPLAN
    REPLAN --> PLAN
    EVALUATE -->|OUI| COMPLETE

    classDef step fill:#162447,stroke:#4472C4,color:#fff,stroke-width:2px
    classDef decision fill:#27AE60,stroke:#1B5E20,color:#fff
    classDef final fill:#e94560,stroke:#1a1a2e,color:#fff,stroke-width:3px

    class OBJECTIVE,DECOMPOSE,PLAN,ACT,OBSERVE,REPLAN step
    class EVALUATE decision
    class COMPLETE final
