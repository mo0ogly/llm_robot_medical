{
  "version": "1.0",
  "last_updated": "2026-04-04",
  "description": "Multi-LLM Provider Configuration for PromptForge - Single Source of Truth for all LLM endpoints, models, and authentication",
  "providers": {
    "ollama": {
      "type": "local",
      "enabled": true,
      "name": "Ollama (Local)",
      "host": "http://127.0.0.1:11434",
      "endpoint": "http://127.0.0.1:11434/api/generate",
      "models": [
        "llama3.2:latest",
        "saki007ster/CybersecurityRiskAnalyst:latest",
        "llama2:latest",
        "mistral:latest"
      ],
      "default_model": "llama3.2:latest",
      "auth": null,
      "parameters": {
        "temperature": {
          "min": 0.0,
          "max": 2.0,
          "default": 0.7,
          "step": 0.1
        },
        "top_p": {
          "min": 0.0,
          "max": 1.0,
          "default": 0.95,
          "step": 0.05
        },
        "top_k": {
          "min": 0,
          "max": 100,
          "default": 40,
          "step": 1
        },
        "num_predict": {
          "min": 1,
          "max": 4096,
          "default": 1024,
          "step": 1
        }
      },
      "timeout_seconds": 120,
      "health_check_path": "/api/tags",
      "notes": "Local inference server. Requires Ollama running on system."
    },
    "anthropic": {
      "type": "cloud",
      "enabled": false,
      "name": "Claude (Anthropic)",
      "endpoint": "https://api.anthropic.com/v1",
      "models": [
        "claude-opus-4-6",
        "claude-sonnet-4-6",
        "claude-haiku-4-5-20251001"
      ],
      "default_model": "claude-opus-4-6",
      "auth": {
        "api_key_env": "ANTHROPIC_API_KEY",
        "method": "header",
        "header_name": "x-api-key"
      },
      "parameters": {
        "temperature": {
          "min": 0.0,
          "max": 1.0,
          "default": 0.7,
          "step": 0.1
        },
        "max_tokens": {
          "min": 1,
          "max": 4096,
          "default": 1024,
          "step": 1
        },
        "top_p": {
          "min": 0.0,
          "max": 1.0,
          "default": 0.95,
          "step": 0.05
        }
      },
      "timeout_seconds": 60,
      "health_check_path": "/health",
      "notes": "Anthropic Claude API. Best for complex reasoning and medical adversarial testing."
    },
    "openai": {
      "type": "cloud",
      "enabled": false,
      "name": "GPT (OpenAI)",
      "endpoint": "https://api.openai.com/v1",
      "models": [
        "gpt-4o",
        "gpt-4-turbo",
        "gpt-4o-mini",
        "gpt-4"
      ],
      "default_model": "gpt-4o",
      "auth": {
        "api_key_env": "OPENAI_API_KEY",
        "method": "header",
        "header_name": "Authorization",
        "prefix": "Bearer"
      },
      "parameters": {
        "temperature": {
          "min": 0.0,
          "max": 2.0,
          "default": 0.7,
          "step": 0.1
        },
        "max_tokens": {
          "min": 1,
          "max": 4096,
          "default": 1024,
          "step": 1
        },
        "top_p": {
          "min": 0.0,
          "max": 1.0,
          "default": 1.0,
          "step": 0.05
        }
      },
      "timeout_seconds": 60,
      "health_check_path": "/models",
      "notes": "OpenAI GPT-4 and variants. Ultra-popular, widely benchmarked."
    },
    "google": {
      "type": "cloud",
      "enabled": false,
      "name": "Gemini (Google)",
      "endpoint": "https://generativelanguage.googleapis.com/v1beta/models",
      "models": [
        "gemini-2.0-flash",
        "gemini-1.5-pro",
        "gemini-1.5-flash",
        "gemini-1.0-pro"
      ],
      "default_model": "gemini-2.0-flash",
      "auth": {
        "api_key_env": "GOOGLE_API_KEY",
        "method": "query_param",
        "param_name": "key"
      },
      "parameters": {
        "temperature": {
          "min": 0.0,
          "max": 2.0,
          "default": 0.7,
          "step": 0.1
        },
        "max_output_tokens": {
          "min": 1,
          "max": 4096,
          "default": 1024,
          "step": 1
        },
        "top_p": {
          "min": 0.0,
          "max": 1.0,
          "default": 0.95,
          "step": 0.05
        }
      },
      "timeout_seconds": 30,
      "health_check_path": "/models",
      "notes": "Google Gemini API. Very fast (Flash model), good for latency-sensitive testing."
    },
    "groq": {
      "type": "cloud",
      "enabled": false,
      "name": "Groq (Groq Cloud)",
      "endpoint": "https://api.groq.com/openai/v1",
      "models": [
        "llama-3.1-70b-versatile",
        "llama-3.1-8b-instant",
        "mixtral-8x7b-32768",
        "gemma-7b-it"
      ],
      "default_model": "llama-3.1-70b-versatile",
      "auth": {
        "api_key_env": "GROQ_API_KEY",
        "method": "header",
        "header_name": "Authorization",
        "prefix": "Bearer"
      },
      "parameters": {
        "temperature": {
          "min": 0.0,
          "max": 2.0,
          "default": 0.7,
          "step": 0.1
        },
        "max_tokens": {
          "min": 1,
          "max": 4096,
          "default": 1024,
          "step": 1
        },
        "top_p": {
          "min": 0.0,
          "max": 1.0,
          "default": 0.95,
          "step": 0.05
        }
      },
      "timeout_seconds": 15,
      "health_check_path": "/models",
      "notes": "Groq LPU inference engine. FASTEST provider - 10-50ms latency. Perfect for stress-testing."
    },
    "xai": {
      "type": "cloud",
      "enabled": false,
      "name": "Grok (xAI)",
      "endpoint": "https://api.x.ai/v1",
      "models": [
        "grok-3",
        "grok-2",
        "grok-vision-beta"
      ],
      "default_model": "grok-3",
      "auth": {
        "api_key_env": "XAI_API_KEY",
        "method": "header",
        "header_name": "Authorization",
        "prefix": "Bearer"
      },
      "parameters": {
        "temperature": {
          "min": 0.0,
          "max": 2.0,
          "default": 0.7,
          "step": 0.1
        },
        "max_tokens": {
          "min": 1,
          "max": 4096,
          "default": 1024,
          "step": 1
        }
      },
      "timeout_seconds": 45,
      "health_check_path": "/models",
      "notes": "xAI Grok models. New provider, good for jailbreak testing (Grok is known for fewer restrictions)."
    }
  },
  "presets": {
    "medical_testing": {
      "description": "Optimized for medical adversarial testing",
      "temperature": 0.7,
      "max_tokens": 512,
      "providers": ["ollama", "anthropic", "openai"]
    },
    "speed_benchmark": {
      "description": "Fast latency-sensitive testing",
      "temperature": 0.5,
      "max_tokens": 256,
      "providers": ["groq", "google"]
    },
    "comprehensive_comparison": {
      "description": "Compare all enabled providers",
      "temperature": 0.7,
      "max_tokens": 1024,
      "providers": "*all_enabled"
    }
  },
  "feature_flags": {
    "streaming_enabled": true,
    "parallel_compare_enabled": true,
    "caching_enabled": false,
    "rate_limiting_enabled": true,
    "telemetry_enabled": true
  }
}
