{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5173,
      "cwd": "frontend"
    },
    {
      "name": "backend",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "uvicorn", "server:app", "--reload", "--host", "0.0.0.0", "--port", "8042"],
      "port": 8042,
      "cwd": "backend"
    },
    {
      "name": "wiki",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "mkdocs", "serve", "--dev-addr", "127.0.0.1:8001", "--no-livereload"],
      "port": 8001,
      "cwd": "wiki"
    }
  ]
}
